{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"functions": {
		"api/**/*.js": {
			"runtime": "nodejs22.x",
			"memory": 512,
			"maxDuration": 10
		}
	},
	"headers": [
		{
			"source": "/api/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "no-store"
				}
			]
		}
	]
}
